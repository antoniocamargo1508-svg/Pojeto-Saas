# Exemplo de arquivo .env para configuração do app
# Copie este arquivo para .env e preencha as credenciais reais.

# Banco de dados (opcional)
# DATABASE_URL=sqlite:///app.db

# SMTP para envio automático de recuperação de senha e alertas
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu.email@empresa.com
SMTP_PASSWORD=sua_senha_de_app_ou_token
SMTP_ENCRYPTION=tls
SMTP_TO=destinatario@empresa.com
SMTP_FROM=seu.email@empresa.com
